---
import CategoryBadge from './CategoryBadge.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  slug: string;
  sourcesCount: number;
  featured?: boolean;
  company?: string;
  companyDomain?: string;
}

const { title, description, pubDate, category, slug, sourcesCount, featured, company, companyDomain } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('de-DE', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
}).format(pubDate);

const href = `/news/${slug}`;
const imageUrl = `/images/articles/${slug}.jpg`;
const fallbackImage = `/images/${category}.jpg`;
const companyLogo = companyDomain ? `https://logo.clearbit.com/${companyDomain}` : null;
---

<article
  class={`bg-white rounded-xl shadow-sm border border-gray-100 hover:shadow-md hover:border-primary-500/20 transition-all duration-200 overflow-hidden group ${
    featured ? 'ring-2 ring-gold' : ''
  }`}
>
  <a href={href} class="block">
    <!-- Image -->
    <div class="relative aspect-video overflow-hidden">
      <img
        src={imageUrl}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
        onerror={`this.src='${fallbackImage}'`}
      />
      <div class="absolute top-3 left-3 flex gap-2">
        <CategoryBadge category={category} />
        {
          featured && (
            <span class="px-2 py-0.5 bg-gold text-dark text-xs font-medium rounded-full">
              ⭐ Top-Story
            </span>
          )
        }
      </div>
      {
        companyLogo && (
          <div class="absolute top-3 right-3 w-8 h-8 bg-white rounded-lg shadow-md p-1 flex items-center justify-center">
            <img
              src={companyLogo}
              alt={company}
              class="w-6 h-6 object-contain"
              onerror="this.parentElement.style.display='none'"
            />
          </div>
        )
      }
    </div>

    <!-- Content -->
    <div class="p-5">
      <div class="flex items-center gap-2 mb-2">
        <time datetime={pubDate.toISOString()} class="text-xs text-gray-400">
          {formattedDate}
        </time>
        {
          company && (
            <span class="text-xs text-primary-500 font-medium">· {company}</span>
          )
        }
      </div>

      <h2
        class="text-lg font-bold text-dark group-hover:text-primary-500 transition-colors mb-2 leading-snug"
      >
        {title}
      </h2>

      <p class="text-gray-600 text-sm leading-relaxed line-clamp-3">
        {description}
      </p>

      <div class="mt-4 flex items-center justify-between">
        <span class="text-xs text-gray-400">
          {sourcesCount} {sourcesCount === 1 ? 'Quelle' : 'Quellen'}
        </span>
        <span
          class="text-sm font-medium text-primary-500 group-hover:text-gold transition-colors inline-flex items-center gap-1"
        >
          Weiterlesen
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"
            ></path>
          </svg>
        </span>
      </div>
    </div>
  </a>
</article>
