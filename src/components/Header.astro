---
const navLinks = [
  { href: '/', label: 'Startseite' },
  { href: '/news', label: 'News' },
  { href: '/ki-digitalisierung', label: 'KI & Digital' },
  { href: '/versicherer', label: 'Versicherer' },
  { href: '/makler', label: 'Makler' },
  { href: '/glossar', label: 'Glossar' },
];

const today = new Date();
const formattedDate = new Intl.DateTimeFormat('de-DE', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(today);
---

<!-- Top Date Bar -->
<div class="bg-dark text-white/60 text-xs border-b border-white/10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-1.5 flex justify-between items-center">
    <span>{formattedDate}</span>
    <span class="hidden sm:inline">Täglich kuratierte Nachrichten aus der Versicherungsbranche</span>
  </div>
</div>

<!-- Masthead -->
<header class="bg-dark text-white shadow-lg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Logo centered like newspaper masthead -->
    <div class="flex items-center justify-center py-5 border-b border-white/10">
      <a href="/" class="flex items-center gap-3 group">
        <div class="relative">
          <div class="w-10 h-10 rounded-full overflow-hidden flex">
            <div class="w-1/2 h-full bg-primary-500"></div>
            <div class="w-1/2 h-full bg-dark border border-white/20"></div>
          </div>
          <div class="absolute -top-1 left-1/2 -translate-x-1/2 w-3 h-3 bg-gold rounded-full"></div>
        </div>
        <div class="text-center">
          <span class="text-2xl md:text-3xl font-extrabold tracking-tight">
            ai.<span class="text-primary-500">versicherung</span>
          </span>
          <div class="text-[10px] uppercase tracking-[0.3em] text-white/40 font-medium hidden sm:block">
            News &amp; Analyse
          </div>
        </div>
      </a>
    </div>

    <!-- Navigation centered -->
    <nav class="hidden md:flex items-center justify-center gap-1 py-2">
      {
        navLinks.map((link, i) => (
          <>
            <a
              href={link.href}
              class="px-3 py-1.5 text-sm font-medium text-white/80 hover:text-primary-400 transition-colors"
            >
              {link.label}
            </a>
            {i < navLinks.length - 1 && (
              <span class="text-white/20 text-xs">|</span>
            )}
          </>
        ))
      }
    </nav>

    <!-- Mobile menu button -->
    <div class="flex md:hidden items-center justify-between py-3">
      <span class="text-sm text-white/60">Menü</span>
      <button
        id="mobile-menu-btn"
        class="p-2 text-white/80 hover:text-white"
        aria-label="Menü öffnen"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <nav id="mobile-menu" class="hidden md:hidden pb-4 space-y-1">
      {
        navLinks.map((link) => (
          <a href={link.href} class="block px-3 py-2 text-sm text-white/80 hover:text-primary-400">
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<!-- Accent line under header -->
<div class="h-[3px] bg-gradient-to-r from-primary-500 via-gold to-primary-500"></div>

<script>
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
