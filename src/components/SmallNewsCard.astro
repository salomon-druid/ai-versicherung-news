---
interface Props {
  title: string;
  pubDate: Date;
  category: string;
  slug: string;
  rank?: number;
}

const { title, pubDate, category, slug, rank } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('de-DE', {
  day: 'numeric',
  month: 'short',
}).format(pubDate);

const href = `/news/${slug}`;

const categoryLabels: Record<string, string> = {
  'ki-digitalisierung': 'KI & Digital',
  versicherer: 'Versicherer',
  versicherungsprodukte: 'Produkte',
  versicherungsumfeld: 'Umfeld',
  makler: 'Makler',
  'risiken-schaeden': 'Risiken',
};
---

<a href={href} class="flex items-start gap-3 py-3 border-b border-gray-100 last:border-0 group hover:bg-gray-50 -mx-2 px-2 rounded transition-colors">
  {rank && (
    <span class="text-2xl font-extrabold text-primary-500/30 leading-none min-w-[28px] text-right">
      {rank}
    </span>
  )}
  <div class="flex-1 min-w-0">
    <p class="text-sm font-semibold text-dark group-hover:text-primary-500 transition-colors leading-snug line-clamp-2">
      {title}
    </p>
    <div class="flex items-center gap-2 mt-1">
      <span class="text-xs text-gray-400">{formattedDate}</span>
      <span class="text-xs text-primary-500 font-medium">{categoryLabels[category] || category}</span>
    </div>
  </div>
</a>
