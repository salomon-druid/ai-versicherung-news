---
interface Props {
  category: string;
  size?: 'sm' | 'md';
}

const { category, size = 'sm' } = Astro.props;

const categoryLabels: Record<string, string> = {
  'ki-digitalisierung': 'KI & Digital',
  versicherer: 'Versicherer',
  versicherungsprodukte: 'Produkte',
  versicherungsumfeld: 'Umfeld',
  makler: 'Makler',
  'risiken-schaeden': 'Risiken',
};

const categoryColors: Record<string, string> = {
  'ki-digitalisierung': 'bg-primary-500/10 text-primary-700 border-primary-500/20',
  versicherer: 'bg-blue-100 text-blue-800 border-blue-200',
  versicherungsprodukte: 'bg-purple-100 text-purple-800 border-purple-200',
  versicherungsumfeld: 'bg-amber-100 text-amber-800 border-amber-200',
  makler: 'bg-teal-100 text-teal-800 border-teal-200',
  'risiken-schaeden': 'bg-rose-100 text-rose-800 border-rose-200',
};

const label = categoryLabels[category] || category;
const colors = categoryColors[category] || 'bg-gray-100 text-gray-800 border-gray-200';
const sizeClasses = size === 'md' ? 'px-3 py-1 text-sm' : 'px-2 py-0.5 text-xs';
---

<span class={`inline-block font-medium rounded-full border ${colors} ${sizeClasses}`}>
  {label}
</span>
