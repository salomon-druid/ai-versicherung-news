---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsCard from '../components/NewsCard.astro';
import { getCollection } from 'astro:content';

const allNews = await getCollection('news');
const sortedNews = allNews.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const categories = [
  { slug: 'ki-digitalisierung', label: 'KI & Digitalisierung', icon: '🤖', count: allNews.filter(n => n.data.category === 'ki-digitalisierung').length },
  { slug: 'versicherer', label: 'Versicherer', icon: '🏢', count: allNews.filter(n => n.data.category === 'versicherer').length },
  { slug: 'versicherungsprodukte', label: 'Produkte', icon: '📦', count: allNews.filter(n => n.data.category === 'versicherungsprodukte').length },
  { slug: 'versicherungsumfeld', label: 'Umfeld', icon: '🌍', count: allNews.filter(n => n.data.category === 'versicherungsumfeld').length },
  { slug: 'makler', label: 'Makler', icon: '🏠', count: allNews.filter(n => n.data.category === 'makler').length },
  { slug: 'risiken-schaeden', label: 'Risiken', icon: '⚡', count: allNews.filter(n => n.data.category === 'risiken-schaeden').length },
];
---

<BaseLayout title="Versicherungsnews – KI, Versicherer, Makler & mehr">
  <!-- Hero Section -->
  <section class="bg-dark text-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <span class="inline-block px-3 py-1 bg-primary-500/20 text-primary-500 text-sm font-medium rounded-full mb-6">
          Täglich aktualisiert
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight mb-6">
          News für die<br />
          <span class="text-primary-500">Versicherungsbranche</span>
        </h1>
        <p class="text-xl text-white/70 leading-relaxed mb-8">
          KI, Versicherer, Makler, Produkte und Risiken – täglich kuratierte Nachrichten
          mit Quellenangaben aus der Versicherungswirtschaft.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="/news"
            class="px-6 py-3 bg-primary-500 text-white font-semibold rounded-lg hover:bg-primary-600 transition-colors"
          >
            Alle News lesen
          </a>
          <a
            href="/glossar"
            class="px-6 py-3 border border-white/20 text-white font-semibold rounded-lg hover:bg-white/10 transition-colors"
          >
            Glossar
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="bg-white border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="flex flex-wrap justify-center gap-8 md:gap-16 text-center">
        <div>
          <p class="text-3xl font-bold text-dark">{allNews.length}</p>
          <p class="text-sm text-gray-500">Artikel</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-dark">6</p>
          <p class="text-sm text-gray-500">Themenfelder</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-dark">{allNews.reduce((acc, n) => acc + (n.data.sources?.length || 0), 0)}</p>
          <p class="text-sm text-gray-500">Quellen</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-dark">4</p>
          <p class="text-sm text-gray-500">CronJobs / Tag</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest News - Uniform Grid -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold text-dark">Aktuelle News</h2>
      <a href="/news" class="text-sm font-medium text-primary-500 hover:text-gold transition-colors">
        Alle anzeigen →
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        sortedNews.slice(0, 6).map((article) => (
          <NewsCard
            title={article.data.title}
            description={article.data.description}
            pubDate={article.data.pubDate}
            category={article.data.category}
            slug={article.slug}
            sourcesCount={article.data.sources?.length || 0}
            featured={article.data.featured}
            company={article.data.company}
            companyDomain={article.data.companyDomain}
          />
        ))
      }
    </div>
  </section>

  <!-- Categories -->
  <section id="kategorien" class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-dark mb-8 text-center">Themenfelder</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
        {
          categories.map((cat) => (
            <a
              href={`/${cat.slug}`}
              class="bg-bg hover:bg-primary-500/5 border border-gray-100 hover:border-primary-500/20 rounded-xl p-4 text-center transition-all group"
            >
              <span class="text-3xl block mb-2">{cat.icon}</span>
              <span class="text-sm font-semibold text-dark group-hover:text-primary-500 transition-colors block">
                {cat.label}
              </span>
              <span class="text-xs text-gray-400">{cat.count} Artikel</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="bg-dark py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-4xl mb-4 block">📬</span>
      <h2 class="text-3xl font-bold text-white mb-4">Keine News verpassen</h2>
      <p class="text-white/70 mb-8">
        Erhalte die wichtigsten Versicherungs-News direkt in dein Postfach.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <input
          type="email"
          placeholder="deine@email.de"
          class="flex-1 px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder:text-white/40 focus:outline-none focus:ring-2 focus:ring-primary-500"
        />
        <button
          type="button"
          onclick="alert('Danke für dein Interesse! Der Newsletter wird bald verfügbar sein.')"
          class="px-6 py-3 bg-gold text-dark font-semibold rounded-lg hover:bg-gold/90 transition-colors"
        >
          Anmelden
        </button>
      </div>
      <p class="text-white/40 text-xs mt-4">Kein Spam. Jederzeit abmeldbar.</p>
    </div>
  </section>
</BaseLayout>
