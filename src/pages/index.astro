---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsCard from '../components/NewsCard.astro';
import { getCollection } from 'astro:content';

const allNews = await getCollection('news');
const sortedNews = allNews.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const latestNews = sortedNews.slice(0, 6);
const featuredArticle = sortedNews.find((n) => n.data.featured) || sortedNews[0];
const remainingNews = latestNews.filter((n) => n !== featuredArticle);

const categories = [
  { slug: 'ki-anwendungen', label: 'KI-Anwendungen', icon: '🤖', count: allNews.filter(n => n.data.category === 'ki-anwendungen').length },
  { slug: 'regulierung', label: 'Regulierung', icon: '⚖️', count: allNews.filter(n => n.data.category === 'regulierung').length },
  { slug: 'makler', label: 'Makler', icon: '🏢', count: allNews.filter(n => n.data.category === 'makler').length },
  { slug: 'maerkte', label: 'Märkte', icon: '📈', count: allNews.filter(n => n.data.category === 'maerkte').length },
  { slug: 'innovation', label: 'Innovation', icon: '💡', count: allNews.filter(n => n.data.category === 'innovation').length },
  { slug: 'risikomanagement', label: 'Risikomanagement', icon: '🛡️', count: allNews.filter(n => n.data.category === 'risikomanagement').length },
];
---

<BaseLayout title="Tägliche KI-News für die Versicherungsbranche">
  <!-- Hero Section -->
  <section class="bg-navy text-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <span class="inline-block px-3 py-1 bg-cyan/20 text-cyan text-sm font-medium rounded-full mb-6">
          Täglich aktualisiert
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight mb-6">
          KI transformiert die<br />
          <span class="text-cyan">Versicherungsbranche</span>
        </h1>
        <p class="text-xl text-white/70 leading-relaxed mb-8">
          Nachrichten, Analysen und Einblicke zu künstlicher Intelligenz in der
          Versicherungswirtschaft. Täglich kuratiert mit Quellenangaben.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="/news"
            class="px-6 py-3 bg-cyan text-navy font-semibold rounded-lg hover:bg-cyan/90 transition-colors"
          >
            Alle News lesen
          </a>
          <a
            href="/glossar"
            class="px-6 py-3 border border-white/20 text-white font-semibold rounded-lg hover:bg-white/10 transition-colors"
          >
            Glossar
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="bg-white border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="flex flex-wrap justify-center gap-8 md:gap-16 text-center">
        <div>
          <p class="text-3xl font-bold text-navy">{allNews.length}</p>
          <p class="text-sm text-gray-500">Artikel</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-navy">6</p>
          <p class="text-sm text-gray-500">Kategorien</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-navy">{allNews.reduce((acc, n) => acc + (n.data.sources?.length || 0), 0)}</p>
          <p class="text-sm text-gray-500">Quellen</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-navy">100%</p>
          <p class="text-sm text-gray-500">Quellenangaben</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured + Latest -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h2 class="text-2xl font-bold text-navy mb-8">Aktuelle News</h2>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Featured Article -->
      {
        featuredArticle && (
          <div class="lg:col-span-2">
            <NewsCard
              title={featuredArticle.data.title}
              description={featuredArticle.data.description}
              pubDate={featuredArticle.data.pubDate}
              category={featuredArticle.data.category}
              slug={featuredArticle.slug}
              sourcesCount={featuredArticle.data.sources?.length || 0}
              featured={true}
            />
          </div>
        )
      }

      <!-- Sidebar -->
      <div class="space-y-6">
        {
          remainingNews.slice(0, 3).map((article) => (
            <NewsCard
              title={article.data.title}
              description={article.data.description}
              pubDate={article.data.pubDate}
              category={article.data.category}
              slug={article.slug}
              sourcesCount={article.data.sources?.length || 0}
            />
          ))
        }
      </div>
    </div>

    {
      remainingNews.length > 3 && (
        <div class="mt-8 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {remainingNews.slice(3).map((article) => (
            <NewsCard
              title={article.data.title}
              description={article.data.description}
              pubDate={article.data.pubDate}
              category={article.data.category}
              slug={article.slug}
              sourcesCount={article.data.sources?.length || 0}
            />
          ))}
        </div>
      )
    }

    <div class="mt-8 text-center">
      <a
        href="/news"
        class="inline-flex items-center gap-2 px-6 py-3 bg-navy text-white font-semibold rounded-lg hover:bg-navy/90 transition-colors"
      >
        Alle News anzeigen
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </a>
    </div>
  </section>

  <!-- Categories -->
  <section id="kategorien" class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-navy mb-8 text-center">Kategorien</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
        {
          categories.map((cat) => (
            <a
              href={`/${cat.slug}`}
              class="bg-gray-50 hover:bg-cyan/5 border border-gray-100 hover:border-cyan/20 rounded-xl p-4 text-center transition-all group"
            >
              <span class="text-3xl block mb-2">{cat.icon}</span>
              <span class="text-sm font-semibold text-navy group-hover:text-cyan transition-colors block">
                {cat.label}
              </span>
              <span class="text-xs text-gray-400">{cat.count} Artikel</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="bg-navy py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-4xl mb-4 block">📬</span>
      <h2 class="text-3xl font-bold text-white mb-4">Keine News verpassen</h2>
      <p class="text-white/70 mb-8">
        Erhalte die wichtigsten KI-Versicherungs-News direkt in dein Postfach. Kostenlos und unverbindlich.
      </p>
      <div id="newsletter-form" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <input
          type="email"
          id="newsletter-email"
          placeholder="deine@email.de"
          class="flex-1 px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder:text-white/40 focus:outline-none focus:ring-2 focus:ring-cyan"
        />
        <button
          type="button"
          onclick="alert('Danke für dein Interesse! Der Newsletter wird bald verfügbar sein.')"
          class="px-6 py-3 bg-gold text-navy font-semibold rounded-lg hover:bg-gold/90 transition-colors"
        >
          Anmelden
        </button>
      </div>
      <p class="text-white/40 text-xs mt-4">Kein Spam. Jederzeit abmeldbar.</p>
    </div>
  </section>
</BaseLayout>
