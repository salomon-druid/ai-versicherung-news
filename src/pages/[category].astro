---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsCard from '../components/NewsCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  return [
    { params: { category: 'ki-digitalisierung' }, props: { label: 'KI & Digitalisierung', icon: '🤖', description: 'Künstliche Intelligenz, InsurTech, digitale Transformation und neue Technologien in der Versicherungsbranche.' } },
    { params: { category: 'versicherer' }, props: { label: 'Versicherer', icon: '🏢', description: 'Unternehmensnews, Quartalszahlen, Fusionen, Strategiewechsel und Personalien bei Versicherungsunternehmen.' } },
    { params: { category: 'versicherungsprodukte' }, props: { label: 'Versicherungsprodukte', icon: '📦', description: 'Neue Tarife, Produktinnovationen, Vergleiche und Marktanalysen zu Versicherungsprodukten.' } },
    { params: { category: 'versicherungsumfeld' }, props: { label: 'Umfeld & Regulierung', icon: '🌍', description: 'EU-Regulierung, Aufsicht, Marktentwicklung, Zinsen und wirtschaftliche Rahmenbedingungen.' } },
    { params: { category: 'makler' }, props: { label: 'Makler', icon: '🏠', description: 'Vertrieb, Vergütung, Verbände, rechtliche Änderungen und digitale Transformation im Maklerbereich.' } },
    { params: { category: 'risiken-schaeden' }, props: { label: 'Risiken & Schäden', icon: '⚡', description: 'Naturkatastrophen, Cyber-Risiken, Haftungsfälle und aktuelle Schadensereignisse.' } },
  ];
}

const { category } = Astro.params;
const { label, icon, description } = Astro.props;

const allNews = await getCollection('news');
const filteredNews = allNews
  .filter((n) => n.data.category === category)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categories = [
  { slug: 'ki-digitalisierung', label: 'KI & Digitalisierung' },
  { slug: 'versicherer', label: 'Versicherer' },
  { slug: 'versicherungsprodukte', label: 'Produkte' },
  { slug: 'versicherungsumfeld', label: 'Umfeld' },
  { slug: 'makler', label: 'Makler' },
  { slug: 'risiken-schaeden', label: 'Risiken' },
];
---

<BaseLayout title={`${label} – News`} description={description}>
  <section class="bg-dark text-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="text-4xl mb-4 block">{icon}</span>
      <h1 class="text-4xl font-extrabold mb-3">{label}</h1>
      <p class="text-white/70 text-lg max-w-2xl">{description}</p>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="flex flex-wrap gap-2 mb-8">
      <a href="/news" class="px-3 py-1.5 text-sm rounded-full border border-gray-200 bg-white text-gray-600 hover:border-primary-500 transition-colors">
        Alle
      </a>
      {categories.map((cat) => (
        <a
          href={`/${cat.slug}`}
          class={`px-3 py-1.5 text-sm rounded-full border transition-colors ${
            cat.slug === category
              ? 'bg-dark text-white border-dark'
              : 'bg-white text-gray-600 border-gray-200 hover:border-primary-500'
          }`}
        >
          {cat.label}
        </a>
      ))}
    </div>

    {filteredNews.length === 0 ? (
      <div class="text-center py-16">
        <p class="text-xl text-gray-400 mb-4">Noch keine Artikel in dieser Kategorie.</p>
        <a href="/news" class="text-primary-500 hover:underline font-medium">← Zurück zu allen News</a>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {filteredNews.map((article) => (
          <NewsCard
            title={article.data.title}
            description={article.data.description}
            pubDate={article.data.pubDate}
            category={article.data.category}
            slug={article.slug}
            sourcesCount={article.data.sources?.length || 0}
            featured={article.data.featured}
            company={article.data.company}
            companyDomain={article.data.companyDomain}
          />
        ))}
      </div>
    )}
  </section>
</BaseLayout>
