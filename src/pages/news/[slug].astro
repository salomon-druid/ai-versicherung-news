---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import NewsCard from '../../components/NewsCard.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const news = await getCollection('news');
  return news.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.params;
const { article: articleData } = Astro.props;
const { Content } = await render(articleData);

const allNews = await getCollection('news');

// Related articles: same category or shared tags
const relatedArticles = allNews
  .filter(
    (n) =>
      n.slug !== articleData.slug &&
      (n.data.category === articleData.category ||
        n.data.tags?.some((t) => articleData.data.tags?.includes(t)))
  )
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

// More articles: from different categories (diversity)
const moreArticles = allNews
  .filter(
    (n) =>
      n.slug !== articleData.slug &&
      n.data.category !== articleData.category &&
      !relatedArticles.some((r) => r.slug === n.slug)
  )
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const formattedDate = (date: Date) =>
  new Intl.DateTimeFormat('de-DE', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
  }).format(date);
---

<ArticleLayout
  title={articleData.data.title}
  description={articleData.data.description}
  pubDate={articleData.data.pubDate}
  category={articleData.data.category}
  tags={articleData.data.tags}
  sources={articleData.data.sources}
  image={articleData.data.image || `/images/articles/${article}.jpg`}
  slug={article}
>
  <Content />

  <!-- Verwandte Artikel -->
  {
    relatedArticles.length > 0 && (
      <section class="mt-16 pt-8 border-t border-gray-200">
        <h2 class="text-2xl font-bold text-dark mb-6">Verwandte Artikel</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {relatedArticles.map((related) => (
            <a
              href={`/news/${related.slug}`}
              class="group block bg-white rounded-xl overflow-hidden border border-gray-100 hover:shadow-md hover:border-primary-500/20 transition-all"
            >
              <div class="aspect-video overflow-hidden">
                <img
                  src={`/images/articles/${related.slug}.jpg`}
                  alt={related.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                  onerror={`this.src='/images/${related.data.category}.jpg'`}
                />
              </div>
              <div class="p-4">
                <span class="text-xs text-gray-400">{formattedDate(related.data.pubDate)}</span>
                <h3 class="text-sm font-semibold text-dark mt-1 line-clamp-2 group-hover:text-primary-500 transition-colors">
                  {related.data.title}
                </h3>
              </div>
            </a>
          ))}
        </div>
      </section>
    )
  }

  <!-- Weitere interessante Artikel -->
  {
    moreArticles.length > 0 && (
      <section class="mt-12 pt-8 border-t border-gray-200">
        <h2 class="text-xl font-bold text-dark mb-6">Was könnte Sie sonst noch interessieren?</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {moreArticles.map((article) => (
            <NewsCard
              title={article.data.title}
              description={article.data.description}
              pubDate={article.data.pubDate}
              category={article.data.category}
              slug={article.slug}
              sourcesCount={article.data.sources?.length || 0}
              company={article.data.company}
              companyDomain={article.data.companyDomain}
            />
          ))}
        </div>
      </section>
    )
  }
</ArticleLayout>
